{
  "name": "remote-io-dashboard",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build:plugin": "tsup",
    "build:panel": "vite build",
    "build": "pnpm build:plugin && pnpm build:panel",
    "dev:plugin": "tsup --watch",
    "dev:panel": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.plugin.json && tsc --noEmit -p tsconfig.panel.json"
  },
  "dependencies": {
    "@nodalcore/sdk": "file:.yalc/@nodalcore/sdk",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^1.6.0"
  }
}
